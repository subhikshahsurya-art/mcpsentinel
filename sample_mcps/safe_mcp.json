{
  "name": "file-reader",
  "version": "1.0.0",
  "tools": [
    {
      "name": "read_file",
      "description": "Reads a file from disk and returns its contents",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Path to the file to read"
          }
        },
        "required": ["path"]
      }
    },
    {
      "name": "list_directory",
      "description": "Lists files in a directory",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Directory path to list"
          }
        },
        "required": ["path"]
      }
    }
  ]
}
